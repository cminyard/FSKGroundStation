	(text "The FPGA has strict power\nsequencing requirements,\nVCC (1.2V) must be at\nleast .5V before VCC_SPI (3.3V),\nand and then VPP_2.5V.\n\nVCCIO can be done any time after\nVCC, and it's 3.3V, so we can\nshare that with VCC_SPI.\n\nWe use the output of the previous\nstage to drive the enable of the\nnext stage, which must reach .9V\nto enable.  There's a pull down\non the enable inputs to avoid\nthem floating."
		(exclude_from_sim no)
		(at 53.086 176.784 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "66eba230-a793-4930-ae4e-09cb38dbeb11")
	)
